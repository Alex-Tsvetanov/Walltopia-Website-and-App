# Copy to .env and fill in. .env is gitignored — never commit real secrets.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
DB_NAME=walltopia
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
PORT=8787
CORS_ORIGIN=
NODE_ENV=development
# If a "mongodb+srv" connection fails with querySrv/ECONNREFUSED (a DNS problem), force
# public DNS for the SRV lookup. Leave blank to use your OS resolver (with an auto public-DNS retry).
DNS_SERVERS=
